# Neon Auth URL (Better Auth endpoint)
VITE_NEON_AUTH_URL=https://your-project.neonauth.us-east-1.aws.neon.tech/neondb/auth

# Neon Data API URL (PostgREST endpoint)
VITE_DATA_API_URL=https://your-project.apirest.us-east-1.aws.neon.tech/neondb/rest/v1

# Neon database connection string (used by serverless functions)
DATABASE_URL=postgresql://neondb_owner:password@your-project-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Vercel Blob storage token (for image uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Platform admin emails (comma-separated)
VITE_ADMIN_EMAILS=you@example.com
ADMIN_EMAILS=you@example.com
